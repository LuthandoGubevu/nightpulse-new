
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Clubs collection:
    // - Any logged-in user (email/password or Google) can read club data.
    // - Only admin accounts can create, update, or delete clubs. email_verified is
    //   required in addition to the email match, since email/password signup alone
    //   doesn't prove mailbox ownership (only Firebase's global email-uniqueness does) —
    //   Google sign-in satisfies this automatically. Note: the admin write actions in
    //   clubActions.ts run through the Admin SDK, which bypasses these rules entirely and
    //   performs its own equivalent verifyIdToken check server-side — this rule is the
    //   defense-in-depth backstop, not the only enforcement point.
    match /clubs/{clubId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email in ['lgubevu@gmail.com', 'kwezi.nyakaza@gmail.com']
                   && request.auth.token.email_verified == true;
    }

    // Safety ratings subcollection (one vote doc per user per club, doc ID = uid):
    // - All reads and writes go exclusively through ratingActions.ts using the
    //   Firebase Admin SDK, which bypasses these rules entirely and atomically keeps
    //   the per-user vote doc and the parent club's safetyRatingSum/safetyRatingCount
    //   aggregate in sync inside a transaction. A client trusted to write its own vote
    //   doc directly could still desync the aggregate on the clubs doc (or write to
    //   someone else's uid), so this collection is locked down the same way visits is —
    //   no direct client access at all.
    match /clubs/{clubId}/safetyRatings/{uid} {
      allow read, write: if false;
    }

    // Visits collection (heartbeats):
    // - All reads and writes go exclusively through trusted server-side code
    //   (the /api/heartbeat route and Server Actions) using the Firebase Admin SDK,
    //   which bypasses these rules entirely.
    // - No direct client access is permitted, since these documents contain raw
    //   device IDs and precise location data.
    match /visits/{visitId} {
      allow read, write: if false;
    }

    // By default, if no rule above matches a path, access is denied.
    // This means any other collections or paths not explicitly allowed are protected.
  }
}
