
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Clubs collection:
    // - Public read access (this app has no Firebase Auth).
    // - Public write access for now, because admin CRUD (add/update/delete club)
    //   still runs through the client Firestore SDK with no auth check.
    //   CAUTION: this means anyone can modify or delete any club. Lock this down
    //   once admin actions are migrated to the Admin SDK with their own server-side check.
    match /clubs/{clubId} {
      allow read: if true;
      allow write: if true;
    }

    // Visits collection (heartbeats):
    // - All reads and writes now go exclusively through trusted server-side code
    //   (the /api/heartbeat route and Server Actions) using the Firebase Admin SDK,
    //   which bypasses these rules entirely.
    // - No direct client access is permitted, since this app has no Firebase Auth and
    //   these documents contain raw device IDs and precise location data.
    match /visits/{visitId} {
      allow read, write: if false;
    }

    // By default, if no rule above matches a path, access is denied.
    // This means any other collections or paths not explicitly allowed are protected.
  }
}
